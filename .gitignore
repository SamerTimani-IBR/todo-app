# ====================================================================
# Dependencies
# ====================================================================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ====================================================================
# Build outputs
# ====================================================================
dist/
dist-ssr/
build/
out/
*.tsbuildinfo

# ====================================================================
# Vite / Vercel caches
# ====================================================================
.vite/
.vercel/

# ====================================================================
# Environment files — NEVER commit. They contain Supabase + Tap keys.
# Only `.env.example` (with placeholders) should be in the repo.
# ====================================================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ====================================================================
# Supabase CLI local state
# ====================================================================
.supabase/
supabase/.temp/
supabase/.branches/

# ====================================================================
# Logs
# ====================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ====================================================================
# Editor / IDE
# ====================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.fleet/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ====================================================================
# OS-level junk
# ====================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ====================================================================
# Test / coverage outputs (in case you add tests later)
# ====================================================================
coverage/
*.lcov
.nyc_output/

# ====================================================================
# Misc — anything sensitive should live in .env.local (already ignored)
# or in Supabase Edge Function secrets (server-side only).
# ====================================================================
*.pem
*.key
*.p8
*.pfx
